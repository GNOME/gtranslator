#: data/org.gnome.Gtranslator.gschema.xml.in:22
msgid "Warn if file contains fuzzy translations"
msgstr "Егер файлда дәлсіз аудармалар болса, ескерту"

#: data/org.gnome.Gtranslator.gschema.xml.in:23
msgid "If true, warn the user when saving a PO translation file containing fuzzy strings."
