#: data/org.gnome.Gtranslator.gschema.xml.in:68
msgid "Highlight syntax in edit fields"
msgstr "Түзету өрістерінде синтаксисті түспен ерекшелеу"

#: data/org.gnome.Gtranslator.gschema.xml.in:69
msgid "If true, apply syntax highlighting to strings in edit fields."
msgstr "Егер ақиқат болса, түзету өрістеріндегі жолдарға синтаксисті түспен ерекшелеуді қолдану."

#: data/org.gnome.Gtranslator.gschema.xml.in:75
msgid "Make whitespace visible"
msgstr "Бос орындарды көрінетін ету"

#: data/org.gnome.Gtranslator.gschema.xml.in:76
msgid "If true, display whitespace in strings as representative symbols."
msgstr "Егер ақиқат болса, жолдардағы бос орындарды арнайы таңбалар ретінде көрсету."

#: data/org.gnome.Gtranslator.gschema.xml.in:82
msgid "Remove fuzzy status when message is changed"
