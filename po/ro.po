msgid "Remove fuzzy status when message is changed"
msgstr "Elimină starea „de revizuit” când mesajul este modificat"

#: data/org.gnome.Gtranslator.gschema.xml.in:90
msgid "If true, remove fuzzy status from translations when they are changed."
msgstr ""
"Dacă este adevărat, elimină starea „de revizuit” a traducerii când este "
"modificată."

#: data/org.gnome.Gtranslator.gschema.xml.in:96
msgid "Check spelling"
msgstr "Verifică ortografia"

#: data/org.gnome.Gtranslator.gschema.xml.in:97
msgid "If true, check the spelling of translated messages."
msgstr "Dacă este adevărat, verifică ortografia șirurilor traduse."

#: data/org.gnome.Gtranslator.gschema.xml.in:108
msgid "Message list sort order"
msgstr "Ordinea în listă a șirurilor"

#: data/org.gnome.Gtranslator.gschema.xml.in:109
msgid ""
"Sort order to use in the message list. Possible values are “status”, “id”, "
"“original-text” and “translated-text”."
msgstr ""
"Ordinea de folosit în lista cu șiruri. Valorile posibile sunt „status”, "
"„id”, „original-text” și „translated-text”."

#: data/org.gnome.Gtranslator.gschema.xml.in:116
msgid "Show ID column"
msgstr "Arată coloana ID"

#: data/org.gnome.Gtranslator.gschema.xml.in:117
msgid "If true, displays a column with the id of the message on the editor."
msgstr "Dacă este adevărat, afișează în aplicație o coloană cu ID-ul șirului."

#: data/org.gnome.Gtranslator.gschema.xml.in:128
